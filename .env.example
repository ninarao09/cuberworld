# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com
# Settings → API → Project URL + Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Also add these as VITE_ prefixed for client-side use
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Create an account at https://stripe.com
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe webhook secret (Dashboard → Webhooks → Add endpoint)
# Endpoint URL: https://your-domain.com/api/webhook
# Events to listen to: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Create these prices in Stripe Dashboard → Products → Add product
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
