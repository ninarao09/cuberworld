{
  "version": 2,
  "git": {
    "deploymentEnabled": {
      "master": true,
      "dev": true
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "build/client",
  "functions": {
    "api/index.js": {
      "includeFiles": "build/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
